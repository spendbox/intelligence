# Supabase (data only — not used for auth)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL="Folio <notifications@folio.cafe>"

# Session cookie secret (>=32 chars)
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Admin gate
ADMIN_EMAIL=admin@folio.cafe
ADMIN_PASSWORD=

# Cron
CRON_SECRET=replace-with-a-long-random-string

# Paystack (used when admin toggles paystack_enabled = true)
PAYSTACK_SECRET_KEY=

# OpenAI (used by admin's "Generate with AI" + "Polish with AI" buttons,
# and to auto-tag requests on /order)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Email address that gets a notification when a new /order request is submitted
ADMIN_NOTIFICATION_EMAIL=spendbox@gmail.com

# App URL (used in email links and payment callbacks)
APP_URL=http://localhost:3000

# Trial length in days
TRIAL_DAYS=30
