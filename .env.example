# Supabase (data only — not used for auth)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL="Intelligence <hello@yourdomain.com>"

# Session cookie secret (>=32 chars)
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Admin gate (plain email + password set in Vercel env)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=

# Cron
CRON_SECRET=replace-with-a-long-random-string

# App URL (used in email links)
APP_URL=http://localhost:3000

# Trial length in days
TRIAL_DAYS=30
